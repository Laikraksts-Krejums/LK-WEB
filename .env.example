# Sanity. The `production` dataset is public, so reads need no token — the Studio
# authenticates the editor's own session for writes.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Public base URL for page images in R2.
# e.g. https://images.laikrakstskrejums.lv — leave empty locally to stream from the R2 binding.
NEXT_PUBLIC_R2_PUBLIC_URL=

NEXT_PUBLIC_SITE_URL=http://localhost:3000

# "true" only on the live apex domain. Anything else — staging, workers.dev,
# local — serves noindex.
NEXT_PUBLIC_ALLOW_INDEXING=false
